# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code local settings (may contain secrets)
.claude/settings.local.json

# Accidental temp files from Vercel CLI checks
Users*AppData*Temp*vercel-env-check.txt
vercel-env-check.txt

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# PM2 logs (local dev process manager)
.pm2/

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
